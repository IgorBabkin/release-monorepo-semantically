{
  "name": "release-monorepo-semantically",
  "version": "1.8.0",
  "description": "cli commands to manage versioning of package in monorepo and generate changelog",
  "license": "ISC",
  "author": "",
  "main": "dist/index.js",
  "bin": {
    "monorepo-semantic-release": "bin/release.mjs"
  },
  "files": [
    "dist",
    "templates",
    "bin"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IgorBabkin/release-monorepo-semantically.git"
  },
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "commitlint": "commitlint --edit",
    "test": "vitest run",
    "test:e2e": "pnpm run build && vitest run --config vitest.e2e.config.ts",
    "release": "pnpm exec semantic-release",
    "prepare": "husky"
  },
  "dependencies": {
    "commander": "14.0.3",
    "glob": "^10.3.10",
    "handlebars": "^4.7.8",
    "reflect-metadata": "^0.2.2",
    "ts-ioc-container": "^46.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.39.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "semantic-release": "^24.2.9",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
