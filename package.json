{
  "name": "release-monorepo-semantically",
  "version": "1.0.0",
  "description": "cli commands to manage versioning of package in monorepo and generate changelog",
  "license": "ISC",
  "author": "",
  "main": "dist/main.js",
  "bin": {
    "monorepo-semantic-release": "dist/bin/release.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IgorBabkin/release-monorepo-semantically.git"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/main.js",
    "lint": "eslint src/",
    "commitlint": "commitlint --edit",
    "test": "vitest run",
    "test:e2e": "npm run build && vitest run --config vitest.e2e.config.ts",
    "release": "npx semantic-release",
    "prepare": "husky"
  },
  "dependencies": {
    "glob": "^10.3.10",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.39.2",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@types/node": "^22.16.0",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "semantic-release": "^24.2.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  }
}
